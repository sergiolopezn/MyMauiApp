<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyMauiApp.Screens.Animals.components.AnimalItemView">
    <VerticalStackLayout>
        <Frame BorderColor="LightGray" CornerRadius="10" Padding="20" Margin="5">
            <StackLayout Padding="10">
                <Image Source="{Binding imageLink}" HeightRequest="280" Aspect="AspectFill" />
                <Label Text="{Binding name}" FontSize="Large" Style="{StaticResource cardLabelStyle}" />
                <Label Text="{Binding origin}" FontSize="Medium" />
            </StackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentView>
