<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyMauiApp.Screens.ApiRequestPage"
             x:DataType="viewmodel:ApiRequestViewModel"
             xmlns:viewmodel="clr-namespace:MyMauiApp.ViewModel"
             Title="ApiRequestPage">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Button 
            Text="Click Me" 
            VerticalOptions="Center" 
            HorizontalOptions="Center" 
            Command="{Binding LoadDataCommand}"/>
        
        <CollectionView
            ItemsSource="{Binding DataArt}"
            VerticalOptions="FillAndExpand">    
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="10">
                        <Label Text="{Binding title}" FontSize="18" />
                        <Label Text="{Binding publication_history}" FontSize="14" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>