<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyMauiApp.Screens.StylesAndThemes.StylesAndThemes"
             xmlns:local="clr-namespace:MyMauiApp.Screens.StylesAndThemes"
             Title="StylesAndThemes">
    <VerticalStackLayout Padding="20">
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <HorizontalStackLayout Spacing="10" Padding="10">
            <Label Text="Switch Theme" VerticalOptions="Center" />
            <Switch 
                x:Name="darkThemeSwitch"
                IsToggled="{Binding IsDarkThemeOn}"
                VerticalOptions="Center" 
                HorizontalOptions="Center" 
                Toggled="SwitchTheme" />
        </HorizontalStackLayout>
        <Button Text="Outline Button"
            BackgroundColor="Transparent"
            BorderColor="Blue"
            BorderWidth="2"
            TextColor="Blue"
            CornerRadius="20"
            HorizontalOptions="Center"
            VerticalOptions="Center" />
        <Border Stroke="Gray" StrokeThickness="2" StrokeShape="RoundRectangle 10">
            <Entry Text="Outline Entry" BackgroundColor="Transparent" />
        </Border>
    </VerticalStackLayout>
</ContentPage>