<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyMauiApp.MainPage">

    <Grid RowDefinitions="100, Auto, *" 
          ColumnDefinitions=".75*, .25*"
          Padding="10"
          RowSpacing="10">
        <Image
            Grid.ColumnSpan="2"
            Source="dotnet_bot.png"
            />
        <Entry Placeholder="Enter task" Grid.Row="1"/>
        <Button Text="Add" Grid.Row="1" Grid.Column="1"/>
        
        <CollectionView Grid.Row="2" Grid.ColumnSpan="2">
            <CollectionView.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>Task 1</x:String>
                    <x:String>Task 2</x:String>
                    <x:String>Task 3</x:String>
                </x:Array>
            </CollectionView.ItemsSource>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete" BackgroundColor="Red"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Grid Padding="5" Margin="5">
                          <Border>
                              <Label Text="{Binding .}" FontSize="24" Padding="5"/>
                          </Border>
                        </Grid>  
                    </SwipeView>
                    
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
    </Grid>

</ContentPage>
