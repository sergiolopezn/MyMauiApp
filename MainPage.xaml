<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyMauiApp.MainPage"
             xmlns:viewmodel="clr-namespace:MyMauiApp.ViewModel"
             x:DataType="viewmodel:MainViewModel">

    <VerticalStackLayout Padding="20" Spacing="10">
        <Button Text="Go to Components" Command="{Binding NavigateToComponentsCommand}" />
        <Button Text="Add task screen" Command="{Binding NavigateToAddTaskCommand}" />
        <Button Text="Hardware screen" Command="{Binding NavigateHardwareScreenCommand}" />
        <Button Text="Api Request screen" Command="{Binding NavigateToApiRequestScreenCommand}" />
        <Button Text="Navigation screen" Command="{Binding NavigationScreenCommand}" />
        <Button Text="Data Binding screen" Command="{Binding NavigateToDataBindingCommand}" />
        <Button Text="Styles and Themes screen" Command="{Binding NavigateToStylesAndThemesCommand}" />
    </VerticalStackLayout>
</ContentPage>